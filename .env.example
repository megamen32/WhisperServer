# Copy to .env and change values before exposing the server to a network.
API_KEY=dev-local-key
MODEL=base
OPENAI_DEFAULT_MODEL=large-v3
OPENAI_WHISPER_MIN_MODEL=medium
WEBUI_SESSION_TTL_SECONDS=7200

# Telegram bot
TG_BOT_ENABLED=false
TG_BOT_TOKEN=
TG_BOT_SERVER_URL=http://127.0.0.1:7653/transcribe
TG_BOT_API_KEY=
TG_BOT_MODEL=base
TG_BOT_LANG=ru
TG_BOT_MAX_SIZE_MB=40
TG_BOT_CONCURRENCY=4
TG_BOT_HTTP_PROXY=

# CUDA broker
CUDABROKER_CLIENT_ID=whisper
CUDABROKER_WHISPER_TTL_SECONDS=900
